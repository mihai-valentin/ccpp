# ccpp-produced runtime artifacts. This repo is the PRODUCER, not a consumer
# of itself — if a contributor dogfoods ccpp from here, these land in cwd
# and should not be tracked.
.ccpp/
ccpp.lock
ccpp.lock.json
ccpp.config.json

# Local-only project notes / Claude Code session memory — kept out of the
# tracked tree so contributors aren't forced to share their personal scratch.
CLAUDE.md
idea.md
.claude/

# Per-project scratch directories some Claude Code orchestrators write into.
# Harmless to ignore even if the contributor doesn't use one.
.agent-orch/
.worktrees/
