{
  "name": "ccpp",
  "version": "0.2.4",
  "description": "Claude Code skill, slash-command, and subagent distribution from any git host — public or private — with short names, live reload, lockfile-pinned.",
  "license": "MIT",
  "author": "Mihai Valentin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mihai-valentin/ccpp.git"
  },
  "homepage": "https://github.com/mihai-valentin/ccpp#readme",
  "bugs": {
    "url": "https://github.com/mihai-valentin/ccpp/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "cli",
    "skills",
    "commands",
    "plugins",
    "marketplace",
    "git",
    "bitbucket",
    "private-registry"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "ccpp": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:install": "bash scripts/e2e-install.sh",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm test -- --run && npm run typecheck"
  },
  "dependencies": {
    "cac": "^6.7.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
